/* ─── 时期导航 ─── */
.period-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx 8rpx;
  gap: 40rpx;
}

.period-arrow {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--color-text-primary);
  background: var(--color-card);
  border-radius: 32rpx;
  font-weight: 300;
  line-height: 1;
}

.period-arrow:active {
  background: #faf5f5;
}

.arrow-disabled {
  color: var(--color-divider);
}

.period-label {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  min-width: 240rpx;
  text-align: center;
}

/* ─── 模式切换胶囊 ─── */
.mode-toggle {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  padding: 0 32rpx 24rpx;
}

.mode-capsule {
  padding: 12rpx 40rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  background: var(--color-card);
  color: var(--color-text-secondary);
  font-weight: 500;
}

.mode-capsule:active {
  opacity: 0.85;
}

.mode-capsule.active {
  background: var(--color-primary);
  color: #fff;
}

/* ─── 汇总卡片 ─── */
.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  text-align: center;
}

.summary-item {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.summary-label {
  font-size: 24rpx;
}

.summary-value {
  font-size: 36rpx;
  font-weight: 700;
  margin-top: 4rpx;
}

.summary-divider {
  width: 1rpx;
  height: 56rpx;
  background: var(--color-divider);
}

/* ─── 收支类型切换 ─── */
.type-toggle {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  padding: 8rpx 32rpx 24rpx;
}

.type-capsule {
  padding: 14rpx 48rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  background: var(--color-card);
  color: var(--color-text-secondary);
  font-weight: 500;
}

.type-capsule:active {
  opacity: 0.85;
}

.type-capsule.active-expense {
  background: var(--color-expense);
  color: #fff;
}

.type-capsule.active-income {
  background: var(--color-income);
  color: #fff;
}

/* ─── 图表卡片 ─── */
.chart-card {
  margin-top: 0;
  overflow: hidden;
}

.chart-wrap {
  position: relative;
  overflow: hidden;
}

/* ─── 柱状趋势图（纯 View，无 Canvas）─── */
.bar-chart {
  height: 340rpx;
  display: flex;
  align-items: flex-end;
  padding: 0 4rpx;
}

.bar-row {
  flex: 1;
  display: flex;
  align-items: flex-end;
  min-width: 0;
}

.bar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  min-width: 0;
}

.bar-amt {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
  white-space: nowrap;
}

.bar-fill {
  width: 70%;
  min-width: 8rpx;
  max-width: 40rpx;
  border-radius: 8rpx 8rpx 0 0;
  transition: height 0.4s ease;
  min-height: 4rpx;
}

.bar-peak {
  box-shadow: 0 2rpx 8rpx rgba(255, 138, 128, 0.3);
}

.bar-label {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
  white-space: nowrap;
}

.bar-label-peak {
  color: var(--color-text-primary);
  font-weight: 600;
}

.peak-info {
  display: block;
  text-align: center;
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* ─── 分类排行 ─── */
.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
  display: block;
}

.ranking-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-divider);
}

.ranking-item:last-child {
  border-bottom: none;
}

.ranking-left {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.ranking-idx {
  width: 36rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
}

.idx-top {
  color: var(--color-expense);
  font-weight: 700;
}

.ranking-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.ranking-emoji {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.ranking-name {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.ranking-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.ranking-amount-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.ranking-amount {
  font-size: 30rpx;
  font-weight: 700;
}

.ranking-count {
  font-size: 22rpx;
}

.ranking-bar-track {
  width: 100%;
  height: 8rpx;
  background: #F5F0F0;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 4rpx;
}

.ranking-bar-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

.ranking-percent {
  font-size: 22rpx;
}
