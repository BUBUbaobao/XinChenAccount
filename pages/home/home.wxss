/* ─── 粘贴识别横幅 ─── */
.paste-banner {
  display: flex;
  align-items: center;
  margin: 16rpx 32rpx 0;
  padding: 20rpx 24rpx;
  background: var(--color-card);
  border-radius: 32rpx;
  border-left: 8rpx solid var(--color-income);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  animation: slideUp 0.3s ease-out;
}

.paste-banner:active {
  background: #faf5f5;
}

.paste-banner-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.paste-banner-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.paste-banner-title {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.paste-banner-amount {
  font-size: 32rpx;
  font-weight: 700;
  margin-top: 4rpx;
}

.paste-banner-action {
  font-size: 24rpx;
  color: var(--color-income);
  font-weight: 500;
}

/* ─── 头部 ─── */
.header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
}

.greeting-title {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--color-text-primary);
  display: block;
}

.greeting-sub {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-top: 4rpx;
}

.search-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  background: var(--color-card);
  border-radius: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* ─── 概览卡片 ─── */
.overview-card {
  text-align: center;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.overview-label {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--color-text-secondary);
}

.overview-balance {
  display: block;
  font-size: 72rpx;
  font-weight: 700;
  margin: 8rpx 0 20rpx;
}

.overview-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
}

.overview-item {
  display: flex;
  flex-direction: column;
}

.overview-item-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.overview-item-value {
  font-size: 40rpx;
  font-weight: 700;
  margin-top: 4rpx;
}

.overview-divider {
  width: 1rpx;
  height: 48rpx;
  background: var(--color-divider);
}

/* ─── 预算进度条 ─── */
.budget-bar {
  margin-top: 20rpx;
}

.budget-track {
  height: 16rpx;
  border-radius: 8rpx;
  background: #F5F0F0;
  overflow: hidden;
}

.budget-fill {
  height: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, var(--color-expense), var(--color-tertiary));
  transition: width 0.5s ease;
}

.budget-text {
  font-size: 22rpx;
  margin-top: 8rpx;
  display: block;
}

/* ─── 超支提醒 ─── */
.overspent-bar {
  display: flex;
  align-items: flex-start;
  margin: 0 32rpx 16rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 138, 128, 0.12);
  border-radius: 24rpx;
  border-left: 8rpx solid var(--color-expense);
  animation: slideUp 0.3s ease-out;
}

.overspent-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.overspent-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.overspent-text {
  font-size: 26rpx;
  color: var(--color-expense);
  font-weight: 500;
}

/* ─── 今日速览 ─── */
.today-section {
  padding: 0 32rpx;
}

.today-cards {
  display: flex;
  gap: 24rpx;
}

.today-card {
  flex: 1;
  background: rgba(178, 235, 242, 0.2);
  border-radius: 32rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.today-card-icon {
  font-size: 36rpx;
}

.today-card-name {
  font-size: 22rpx;
  margin-top: 4rpx;
}

.today-card-amount {
  font-size: 28rpx;
  font-weight: 700;
  margin-top: 4rpx;
}

.today-empty {
  background: rgba(178, 235, 242, 0.2);
  border-radius: 32rpx;
  padding: 32rpx 20rpx;
  text-align: center;
}

.today-empty-text {
  font-size: 28rpx;
}

/* ─── 最近记录 ─── */
.records-section {
  padding: 0 32rpx;
  margin-top: 32rpx;
}

.records-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.records-title {
  font-size: 32rpx;
  font-weight: 400;
  color: var(--color-text-primary);
}

.records-more {
  font-size: 24rpx;
}

/* ─── 左滑删除（QQ风格跟手拖拽） ─── */
.swipe-cell {
  position: relative;
  overflow: hidden;
}

/* 背后的删除按钮 —— 胶囊形，高度跟随列表项 */
.swipe-action {
  position: absolute;
  right: 0;
  top: 12.5%;
  height: 75%;
  width: 120rpx;
  background: var(--color-expense);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.swipe-action-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

/* 前景滑动层 —— 白色背景覆盖全部，遮挡背后的删除按钮 */
.swipe-content {
  position: relative;
  background: var(--color-card);
  z-index: 1;
  will-change: transform;
}

.load-more {
  text-align: center;
  padding: 24rpx 0;
}
