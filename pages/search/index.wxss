/* ─── 搜索栏 ─── */
.search-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  gap: 16rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--color-card);
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 80rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.search-clear {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  padding: 8rpx;
}

.search-btn {
  background: var(--color-primary);
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.search-btn:active {
  opacity: 0.85;
}

/* ─── 筛选栏 ─── */
.filter-bar {
  padding: 0 32rpx 16rpx;
}

.filter-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.filter-cue {
  color: var(--color-expense);
  font-size: 12rpx;
}

/* ─── 筛选面板 ─── */
.filter-panel {
  margin: 0 32rpx;
  animation: slideUp 0.2s ease-out;
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(-16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.filter-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.filter-label {
  width: 100rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

/* 类型胶囊 */
.filter-capsules {
  display: flex;
  gap: 12rpx;
}

.filter-capsule {
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  background: #F5F0F0;
  color: var(--color-text-secondary);
}

.filter-capsule.active-default {
  background: var(--color-primary);
  color: #fff;
}

.filter-capsule.active-expense {
  background: var(--color-expense);
  color: #fff;
}

.filter-capsule.active-income {
  background: var(--color-income);
  color: #fff;
}

/* 分类选择 */
.filter-picker {
  flex: 1;
  height: 64rpx;
  background: var(--color-bg);
  border-radius: 16rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
}

.picker-arrow {
  font-size: 32rpx;
  color: var(--color-text-secondary);
}

/* 日期 */
.filter-date-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.filter-date-box {
  padding: 10rpx 20rpx;
  background: var(--color-bg);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.date-sep {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 金额 */
.filter-amt-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.filter-amt-input {
  flex: 1;
  height: 64rpx;
  background: var(--color-bg);
  border-radius: 16rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: var(--color-text-primary);
}

/* 筛选按钮 */
.filter-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 8rpx;
}

.filter-reset {
  padding: 14rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg);
}

.btn-small {
  padding: 14rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #fff;
  background: var(--color-primary);
  font-weight: 500;
}

/* ─── 结果 ─── */
.result-header {
  padding: 16rpx 32rpx 0;
}

.record-item {
  padding: 0 32rpx;
  background: var(--color-card);
}

.record-item:active {
  background: #faf5f5;
}

.load-more {
  text-align: center;
  padding: 24rpx 0;
}

/* ─── 初始状态 ─── */
.search-init {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.search-init-icon {
  font-size: 72rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.search-init-text {
  font-size: 28rpx;
}
