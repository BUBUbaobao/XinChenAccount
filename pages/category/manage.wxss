.cat-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}

.cat-item + .cat-item {
  border-top: 1rpx solid var(--color-divider);
}

.cat-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: rgba(178, 235, 242, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.cat-name {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.cat-preset {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background: rgba(178, 235, 242, 0.3);
  color: var(--color-text-secondary);
}

.cat-del {
  font-size: 26rpx;
  color: var(--color-expense);
}

/* ─── 添加区域 ─── */
.add-section {
  margin-top: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
  display: block;
}

.add-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.add-label {
  font-size: 28rpx;
  color: var(--color-text-primary);
  width: 100rpx;
  flex-shrink: 0;
}

.add-input {
  flex: 1;
  font-size: 28rpx;
  padding: 12rpx 16rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
}

.emoji-hint {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  margin-left: 8rpx;
  flex-shrink: 0;
}

.add-btn {
  margin-top: 20rpx;
}

.add-btn.disabled {
  opacity: 0.4;
  pointer-events: none;
}
