/* ─── 顶部栏 ─── */
.ai-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 16rpx;
}

.ai-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.history-icon {
  font-size: 40rpx;
}

.ai-history-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-card);
  border-radius: 36rpx;
}

/* ─── 欢迎状态 ─── */
.welcome-area {
  display: flex;
  justify-content: center;
  padding-top: 80rpx;
}

.welcome-bubble {
  background: #FFF9C4;
  border-radius: 40rpx;
  padding: 40rpx 32rpx;
  max-width: 85%;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.welcome-text {
  font-size: 30rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
}

.welcome-hint {
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* ─── 对话区域 ─── */
.chat-area {
  padding-top: 16rpx;
}

/* ─── 底部操作区 ─── */
.bottom-bar {
  position: fixed;
  bottom: calc(128rpx + constant(safe-area-inset-bottom));
  bottom: calc(128rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  background: var(--color-bg);
  padding: 16rpx 32rpx 0;
  z-index: 1000;
}

.report-btn {
  width: 100%;
  height: 72rpx;
  background: var(--color-primary);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.report-btn:active {
  opacity: 0.85;
}

.report-btn text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.msg-input {
  flex: 1;
  height: 80rpx;
  background: var(--color-card);
  border-radius: 40rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.send-btn {
  width: 120rpx;
  height: 80rpx;
  background: #E0E0E0;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-btn.active {
  background: var(--color-primary);
}

.send-btn text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}
