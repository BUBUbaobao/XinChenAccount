/* ─── 顶部卡片 ─── */
.top-card {
  margin-top: 32rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
  color: #fff;
}

.top-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.top-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
  margin-top: 8rpx;
}

.top-stats {
  display: flex;
  margin-top: 24rpx;
  gap: 48rpx;
}

.top-stat-item {
  display: flex;
  flex-direction: column;
}

.top-stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.top-stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

/* ─── 分组列表 ─── */
.setting-group {
  margin-top: 16rpx;
  padding: 24rpx 0;
}

.group-title {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  padding: 0 32rpx;
  margin-bottom: 8rpx;
  display: block;
}

.setting-row {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
}

.setting-row:active {
  background: #faf5f5;
}

.setting-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.setting-label {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.setting-value {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-right: 8rpx;
}

.setting-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* ─── AI 设置 ─── */
.api-row {
  padding-top: 0;
  padding-bottom: 28rpx;
}

.api-input {
  flex: 1;
  height: 72rpx;
  background: var(--color-bg);
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: var(--color-text-primary);
}

.eye-btn {
  width: 64rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-left: 8rpx;
}

/* ─── Storage 超限警告 ─── */
.storage-warn {
  margin: 24rpx 32rpx;
  padding: 24rpx 32rpx;
  background: rgba(255, 138, 128, 0.12);
  border-radius: 24rpx;
  border-left: 8rpx solid var(--color-expense);
  font-size: 26rpx;
  color: var(--color-expense);
  line-height: 1.5;
}
