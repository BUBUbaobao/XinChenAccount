.tx-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: var(--color-card);
  box-sizing: border-box;
}

.tx-item:active {
  background: #faf5f5;
}

.tx-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: rgba(178, 235, 242, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.tx-icon {
  font-size: 40rpx;
}

.tx-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.tx-name {
  font-size: 32rpx;
  font-weight: 400;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tx-meta {
  font-size: 24rpx;
  font-weight: 400;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tx-amount {
  font-size: 32rpx;
  font-weight: 700;
  flex-shrink: 0;
  margin-left: 16rpx;
}
