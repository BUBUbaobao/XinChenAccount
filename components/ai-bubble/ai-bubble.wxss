.bubble-wrap {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  padding: 0 32rpx;
}

.bubble-wrap.user {
  flex-direction: row-reverse;
}

.bubble-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* ─── 气泡 ─── */
.bubble-content {
  max-width: 75%;
  padding: 20rpx 24rpx;
  border-radius: 40rpx;
}

.bubble-content.assistant {
  margin-left: 12rpx;
  background: #FFF9C4;
  border-bottom-left-radius: 8rpx;
}

.bubble-content.user {
  margin-right: 12rpx;
  background: var(--color-card);
  border-bottom-right-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.bubble-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--color-text-primary);
  white-space: pre-wrap;
  word-break: break-all;
}

/* ─── Markdown 样式 ─── */
.md-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--color-text-primary);
}

.md-bold {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.6;
  color: var(--color-text-primary);
}

.md-italic {
  font-size: 28rpx;
  font-style: italic;
  line-height: 1.6;
  color: var(--color-text-secondary);
}

.md-h3 {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.8;
  color: var(--color-text-primary);
  display: block;
  margin-top: 8rpx;
}

.md-li {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--color-text-primary);
  padding-left: 12rpx;
  display: block;
}

.md-br {
  height: 12rpx;
  display: block;
}

/* ─── 三点加载动画 ─── */
.loading-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 4rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
  background: #BDBDBD;
  animation: dotPulse 1.4s ease-in-out infinite;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}
