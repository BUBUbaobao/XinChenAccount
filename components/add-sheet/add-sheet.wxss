/* ─── 遮罩 ─── */
.sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 1100;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s ease, visibility 0.25s ease;
}

.sheet-mask.show {
  opacity: 1;
  visibility: visible;
}

/* ─── 面板 ─── */
.sheet-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFE;
  border-radius: 48rpx 48rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  max-height: 90vh;
  display: flex;
  flex-direction: column;
}

.sheet-panel.show {
  transform: translateY(0);
}

/* scroll-view 接管滚动，手指可拖拽 */
.sheet-scroll {
  flex: 1;
  max-height: 85vh;
  box-sizing: border-box;
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-top: 24rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ─── 拖拽把手 ─── */
.sheet-handle {
  width: 80rpx;
  height: 8rpx;
  border-radius: 32rpx;
  background: #E8D5D8;
  margin: 0 auto 24rpx;
}

/* ─── 类型切换 ─── */
.type-switch {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.type-tab {
  padding: 12rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 400;
  color: var(--color-text-secondary);
  background: #F5F5F5;
  transition: all 0.2s;
}

.type-tab.active.expense {
  background: var(--color-expense);
  color: #fff;
  font-weight: 700;
}

.type-tab.active.income {
  background: var(--color-income);
  color: #fff;
  font-weight: 700;
}

/* ─── 分类网格 ─── */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.cat-item {
  width: 23%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  border-radius: 24rpx;
  margin-bottom: 12rpx;
  transition: background 0.15s;
}

.cat-item.selected {
  background: rgba(248, 187, 208, 0.2);
}

.cat-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: rgba(178, 235, 242, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.cat-item.selected .cat-icon {
  background: rgba(248, 187, 208, 0.35);
}

.cat-name {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.cat-item.selected .cat-name {
  color: var(--color-primary);
}

/* ─── 金额显示 ─── */
.amount-display {
  text-align: center;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
}

.amount-value {
  font-size: 72rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

/* ─── 数字键盘 ─── */
.keypad {
  width: 100%;
  box-sizing: border-box;
  background: #FAFAFA;
  border-radius: 32rpx;
  padding: 8rpx;
  margin-bottom: 16rpx;
}

.key-row {
  display: flex;
  width: 100%;
}

.key {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 400;
  color: var(--color-text-primary);
  border-radius: 20rpx;
  margin: 4rpx;
  background: #fff;
  box-sizing: border-box;
}

.key:active {
  background: #F0F0F0;
}

.key-delete {
  background: #F5F5F5;
}

.key-delete text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
}

.key-empty {
  background: transparent;
}

/* ─── 可选信息区 ─── */
.extra-section {
  margin-bottom: 16rpx;
}

.extra-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.extra-toggle text {
  font-size: 24rpx;
}

.extra-content {
  background: #FAFAFA;
  border-radius: 24rpx;
  padding: 16rpx 24rpx;
}

.extra-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.extra-row + .extra-row {
  border-top: 1rpx solid var(--color-divider);
}

.extra-label {
  font-size: 28rpx;
  color: var(--color-text-primary);
  flex-shrink: 0;
  width: 100rpx;
}

.extra-input {
  flex: 1;
  font-size: 28rpx;
  text-align: right;
  color: var(--color-text-primary);
}

.picker-display {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.picker-arrow {
  font-size: 36rpx;
  color: var(--color-text-secondary);
}

/* ─── 保存按钮（绿底白字） ─── */
.save-section {
  padding: 16rpx 0 24rpx;
}

.save-btn {
  width: 100%;
  background-color: var(--color-income);
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  padding: 24rpx 0;
  transition: opacity 0.2s;
}

.save-btn:active {
  opacity: 0.85;
}

.save-btn.disabled {
  opacity: 0.4;
  pointer-events: none;
}
