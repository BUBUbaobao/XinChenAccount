.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.empty-sub {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
  opacity: 0.7;
}
